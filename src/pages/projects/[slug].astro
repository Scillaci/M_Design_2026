---
import BaseLayout from '../../layouts/base.astro';
import Vimeo from '../../components/vimeo.astro';
import Details from '../../components/details.astro';
import Thumbs from '../../components/thumbs.astro';
import Bottom from '../../components/bottom.astro';
import { getDisplayTitle } from '../../utils/getDisplayTitle';
import TitleLines from '../../components/titleLines.astro';

import { getProjects } from '../../utils/getProjects';
import type { Project } from '../../utils/types';

export async function getStaticPaths() {
  const { projects } = getProjects();

  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props as { project: Project };
---

<BaseLayout title={project.title}>

  <div class="page">
    <div class="title">

      <div class="title-row">
          <a href="/" title="back" class="back-icon">
            <img class="back" src="/icon/arrow_icon.svg" alt="back" />
          </a>

          <div class="title-copy">
            <h1>
              <TitleLines lines={getDisplayTitle(project)} />
            </h1>

            <h2>{project.subtitle}</h2>
          </div>
      </div>

    </div>


    <div class="grid">
  <div class="main">
    <Vimeo project={project} />

    <Details
      project={project}
      blockId="details-unten"
      panelId={`details-unten-panel-${project.slug}`}
    />

    <Thumbs thumbs={project.thumbs ?? []} />

    <Bottom />
  </div>

  <Details
    project={project}
    blockId="details-rechts"
    panelId={`details-rechts-panel-${project.slug}`}
  />
</div>

    
  </div>
  
</BaseLayout>