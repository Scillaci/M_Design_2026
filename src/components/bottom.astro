---
import nav from '../data/navigation/navigation.json';
---

<div class="bottom">

    <ul class="bottom-left">
        {nav.about.map((item) => (
        <li>
            <a href={item.href}>{item.label}</a>
        </li>
        ))}
    </ul>

    <ul class="bottom-right">
        {nav.legal.map((item) => (
        <li>
            <a href={item.href}>{item.label}</a>
        </li>
        ))}
    </ul>

    <div class="background"></div>

</div>


