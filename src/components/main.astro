---
import FeaturedTitles from './featuredTitles.astro';
import FeaturedMedia from './featuredMedia.astro';
import FeaturedDetails from './featuredDetails.astro';
import Tiles from '../components/tiles.astro';
import Bottom from '../components/bottom.astro';
import type { Project } from '../utils/types';
import { toFilterData } from '../utils/filterData';

interface Props {
  projects: Project[];
  featuredProjects: Project[];
  alwaysFeaturedProjects: Project[];
  currentIndex: number;  
}

const {projects, featuredProjects, alwaysFeaturedProjects, currentIndex } = Astro.props as Props;
const alwaysFeaturedSlugs = new Set(alwaysFeaturedProjects.map((project) => project.slug));
---

<div id="featured-items-data" hidden>
  {featuredProjects.map((item) => (
    <div
      class="js-featured-data"
      data-featured-slug={item.slug}
      data-category={toFilterData(item.category)}
      data-expertise={toFilterData(item.expertise)}
      data-always-featured={alwaysFeaturedSlugs.has(item.slug) ? 'true' : 'false'}
    />
  ))}
</div>

<div id="featured-state" hidden></div>

<FeaturedTitles 
  featuredProjects={featuredProjects}
  currentIndex={currentIndex}
/>

<div class="grid">
  <div class="main">

    <FeaturedMedia
      featuredProjects={featuredProjects}
      currentIndex={currentIndex}
    />

    <FeaturedDetails
      featuredProjects={featuredProjects}
      currentIndex={currentIndex}
      containerId="details-inline"
      variantClass="js-featured-details-bottom"
      panelPrefix="details-inline-panel"
    />

    <Tiles projects={projects} />

    <Bottom />
  </div>

  <FeaturedDetails
      featuredProjects={featuredProjects}
      currentIndex={currentIndex}
      containerId="details-sidebar"
      variantClass="js-featured-details-right"
      panelPrefix="details-sidebar-panel"
  />

</div>