---
import type { Project } from '../utils/types';

const { project, detailsId } = Astro.props as {
  project: Project;
  detailsId?: string;
};

const id = detailsId ?? `details-${project.slug}`;

const rows = [
  { label: "client", value: project.client },
  { label: "role", value: project.role?.join(" | ") },
  ...(project.collaborators ?? []).map((item) => ({
    label: item.title,
    value: item.name
  })),
  { label: "year", value: project.year }
].filter((row) => row.value);
---

<div class="case">

  {project.overview?.map((text) => (
    <p class="overview">{text}</p>
  ))}

  <div class="details">

     <button
        class="js-toggle" title="Details"
        data-toggle={`this .arrow_icon, #${id}`}> 

        <div class="arrow_button">
          

            <div class="arrow_icon">
              <img src="/icon/arrow_icon.svg" alt="arrow" />
            </div>

            <h3>Details</h3>

        </div>

      </button>
  </div>

  <div id={id} class="details_hidden">
      <div class="details_inner">

        {project.overview?.map((text) => (
          <p class="overview_m">{text}</p>
        ))}

        {rows.map((row) => (
          <>
            <h4>{row.label}</h4>
            <p>{row.value}</p>
          </>
        ))}
      </div>
  </div>

</div>

